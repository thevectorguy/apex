# GROQ_API_KEY: Required for My Coach transcription and report generation.
GROQ_API_KEY="YOUR_GROQ_API_KEY"

# GROQ_MODEL: Text model used for conversation normalization and coaching reports.
GROQ_MODEL="llama-3.3-70b-versatile"

# GROQ_TRANSCRIPTION_MODEL: Speech-to-text model used for uploaded and recorded audio.
GROQ_TRANSCRIPTION_MODEL="whisper-large-v3-turbo"

# MY_COACH_API_PORT: Local backend port for the My Coach API.
MY_COACH_API_PORT="8787"

# VITE_APP_URL / VITE_APP_BASE_PATH: Public app URL and mount path used for Keycloak callbacks.
VITE_APP_URL="http://localhost:3000/DILOS/suzuki"
VITE_APP_BASE_PATH="/DILOS/suzuki"

# VITE_KEYCLOAK_*: Public Keycloak settings for the browser PKCE flow.
VITE_KEYCLOAK_LOGIN_URL="https://suzukimotorcycle-qa.niit.com"
VITE_KEYCLOAK_REALM="suzuki-motorcycle-qa"
VITE_KEYCLOAK_CLIENT_ID="dilos-ai"

# VITE_API_BASE_URL: Optional override for API origin. Leave blank to use same-origin /api routes.
VITE_API_BASE_URL=""

# VITE_PRODUCT_AUTHORITY_*: Product Authority redirect values for same-realm SSO.
VITE_PRODUCT_AUTHORITY_ORIGIN="https://raise-dev.niit.com"
VITE_PRODUCT_AUTHORITY_REGISTRATION_ID="keycloak-suzuki-qa-prodiq"
VITE_PRODUCT_AUTHORITY_HOME_PATH="/ProdIQ/suzuki/"

# MONGODB_URI / MONGODB_DB_NAME: Required for My Coach persistence.
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB_NAME="dilos"

# AWS S3: Required for My Coach audio storage.
AWS_REGION="ap-south-1"
AWS_S3_BUCKET_NAME_OUT="stackroute-spark-dev-out"
AWS_S3_BUCKET_NAME_IN="stackroute-spark-dev-in"
AWS_AUDIO_PATH="uat/dilos/recordings"
AWS_S3_ACCESS_KEY="your-access-key-id"
AWS_S3_SECRET_KEY="your-secret-access-key"
AWS_SESSION_TOKEN=""
AWS_S3_ENDPOINT=""
AWS_S3_FORCE_PATH_STYLE="false"

# PRODUCT_AUTHORITY_ORIGIN: Base origin for Product Authority auth redirects.
PRODUCT_AUTHORITY_ORIGIN="https://raise-dev.niit.com"

# PRODUCT_AUTHORITY_REGISTRATION_ID: Product Authority registration identifier.
PRODUCT_AUTHORITY_REGISTRATION_ID="keycloak-tvs-qa-prodiq"

# PRODUCT_AUTHORITY_USERNAME: Server-side Product Authority practice login username.
PRODUCT_AUTHORITY_USERNAME="your-product-authority-username"

# PRODUCT_AUTHORITY_PASSWORD: Server-side Product Authority practice login password.
PRODUCT_AUTHORITY_PASSWORD="your-product-authority-password"
