# GROQ_API_KEY: Required for My Coach transcription and report generation.
GROQ_API_KEY="YOUR_GROQ_API_KEY"

# GROQ_MODEL: Text model used for conversation normalization and coaching reports.
GROQ_MODEL="llama-3.3-70b-versatile"

# GROQ_TRANSCRIPTION_MODEL: Speech-to-text model used for uploaded and recorded audio.
GROQ_TRANSCRIPTION_MODEL="whisper-large-v3-turbo"

# MY_COACH_API_PORT: Local backend port for the My Coach API.
MY_COACH_API_PORT="8787"

# MY_COACH_STORAGE_PATH: Optional absolute or relative path for local SQLite/audio/report storage.
# Local dev only. Vercel deployments should use Supabase instead.
MY_COACH_STORAGE_PATH="./server/storage"

# PRODUCT_AUTHORITY_ORIGIN: Base origin for Product Authority auth redirects.
PRODUCT_AUTHORITY_ORIGIN="https://raise-dev.niit.com"

# PRODUCT_AUTHORITY_REGISTRATION_ID: Product Authority registration identifier.
PRODUCT_AUTHORITY_REGISTRATION_ID="keycloak-tvs-qa-prodiq"

# PRODUCT_AUTHORITY_USERNAME: Server-side Product Authority practice login username.
PRODUCT_AUTHORITY_USERNAME="your-product-authority-username"

# PRODUCT_AUTHORITY_PASSWORD: Server-side Product Authority practice login password.
PRODUCT_AUTHORITY_PASSWORD="your-product-authority-password"

# SUPABASE_URL: Required for Vercel-safe persistent metadata and audio storage.
SUPABASE_URL="https://your-project.supabase.co"

# SUPABASE_SECRET_KEY: Preferred server-side Supabase secret key for the My Coach backend.
# Legacy fallback: SUPABASE_SERVICE_ROLE_KEY also works for older projects.
SUPABASE_SECRET_KEY="your-supabase-secret-key"
SUPABASE_SERVICE_ROLE_KEY=""

# SUPABASE_AUDIO_BUCKET: Storage bucket for uploaded/recorded audio clips.
SUPABASE_AUDIO_BUCKET="my-coach-audio"
