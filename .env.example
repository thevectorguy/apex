# GROQ_API_KEY: Required for My Coach transcription and report generation.
GROQ_API_KEY="YOUR_GROQ_API_KEY"

# GROQ_MODEL: Text model used for conversation normalization and coaching reports.
GROQ_MODEL="llama-3.3-70b-versatile"

# GROQ_TRANSCRIPTION_MODEL: Speech-to-text model used for uploaded and recorded audio.
GROQ_TRANSCRIPTION_MODEL="whisper-large-v3-turbo"

# MY_COACH_API_PORT: Local backend port for the My Coach API.
MY_COACH_API_PORT="8787"

# MY_COACH_STORAGE_PATH: Optional absolute or relative path for local SQLite/audio/report storage.
MY_COACH_STORAGE_PATH="./server/storage"
